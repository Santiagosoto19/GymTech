# Shared
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Gateway
GATEWAY_PORT=8080
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
AUTH_SERVICE_URL=http://auth-service:3001
MEMBERSHIP_SERVICE_URL=http://membership-service:3002
ACTIVITY_SERVICE_URL=http://activity-service:3003
REPORTING_SERVICE_URL=http://reporting-service:3004
NOTIFICATION_SERVICE_URL=http://notification-service:3005

# Auth Service
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres

# Membership Service
MEMBERSHIP_DB_HOST=membership-db
MEMBERSHIP_DB_PORT=5432
MEMBERSHIP_DB_NAME=membership_db
MEMBERSHIP_DB_USER=postgres
MEMBERSHIP_DB_PASSWORD=postgres

# Activity Service
ACTIVITY_DB_HOST=activity-db
ACTIVITY_DB_PORT=5432
ACTIVITY_DB_NAME=activity_db
ACTIVITY_DB_USER=postgres
ACTIVITY_DB_PASSWORD=postgres

# Reporting Service
REPORTING_DB_HOST=reporting-db
REPORTING_DB_PORT=5432
REPORTING_DB_NAME=reporting_db
REPORTING_DB_USER=postgres
REPORTING_DB_PASSWORD=postgres

# Notification Service
NOTIFICATION_DB_HOST=notification-db
NOTIFICATION_DB_PORT=5432
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=postgres
NOTIFICATION_DB_PASSWORD=postgres

# Frontend
FRONTEND_PORT=80
